# Crossborder Trend Report env example
# Copy to .env locally if needed. Do not commit real keys.
# Sensitive DB / token config should live in credentials.txt
DB_TARGET=remote
SERVER_PORT=8090
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5174
SOURCE_MODE=external
AUTH_ENABLED=false
JWT_SECRET=dev-only-change-me
JWT_EXPIRE_MINUTES=720
# Required when AUTH_ENABLED=true on a fresh database. Do not commit a real value.
INITIAL_ADMIN_PASSWORD=
PLATFORM_FEE_RATE=0.12
PAYMENT_FEE_RATE=0.03
TAX_RATE=0
DEFAULT_AD_COST_CNY=0
MYSQL_HOST=
MYSQL_PORT=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
DB_POOL_MAX_SIZE=3
DB_POOL_MIN_IDLE=0
APIFY_TOKEN=
RAINFOREST_API_KEY=
KEEPA_API_KEY=
SERPAPI_KEY=
GOOGLE_TRENDS_ENABLED=true
GOOGLE_TRENDS_REGIONS=JP,US,SG
FRANKFURTER_ENABLED=true
WOOCOMMERCE_ENABLED=true
WOOCOMMERCE_STORE_URLS=https://www.somethingfromjapan.com
# Optional when Google or another upstream is unreachable from the current network.
OUTBOUND_HTTP_PROXY=
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
YAHOO_SHOPPING_CLIENT_ID=
AI_ENRICHMENT_ENABLED=true
DEEPSEEK_API_KEY=
